# Copy this to .env and fill in real values
# NEVER commit .env to git

# Database — example: postgresql://username:password@host:port/database
DATABASE_URL=

# JWT — generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# External APIs
OPENWEATHER_API_KEY=

# Email alerts
RESEND_API_KEY=
RESEND_SENDER_EMAIL=
RESEND_TEST_RECIPIENT=
ALERT_FROM_EMAIL=

# SUPERADMIN_CREDENTIALS
SUPERADMIN_EMAIL= ""
SUPERADMIN_PASSWORD= ""

# Frontend URL (for CORS)
FRONTEND_URL=

# Development settings
DEBUG=True
LOG_LEVEL=INFO
