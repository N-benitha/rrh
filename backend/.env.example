# Copy this to .env and fill in real values
# NEVER commit .env to git

# Database — example: postgresql://username:password@host:port/database
DATABASE_URL=

# JWT — generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# External APIs
OPENWEATHER_API_KEY=

# Email alerts
RESEND_API_KEY=
ALERT_FROM_EMAIL=

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=

# Development settings
DEBUG=True
LOG_LEVEL=INFO
