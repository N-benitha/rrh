# Copy this to .env and fill in real values
# NEVER commit .env to git

#example postgresql://username:password@host:port/database
DATABASE_URL=

# JWT — generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# External APIs
OPENWEATHER_API_KEY=

# Email alerts (Week 3)
RESEND_API_KEY=
ALERT_FROM_EMAIL=

# Frontend URL (for CORS)
FRONTEND_URL=
